model Availability {
  id           String            @id @default(uuid())
  technicianId String
  technician   TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  dayOfWeek    Int     
  startTime    String  
  endTime      String  
  isAvailable  Boolean  @default(true)

  @@map("availability")
  
}