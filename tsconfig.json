{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDirs": ["./src", "./generated/prisma"], 
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "generated/prisma/**/*"], 
  "exclude": ["node_modules", "dist"]
}
